# ── CMS ──────────────────────────────────────────────────────────────────────
# Set to "sanity" to use Sanity CMS; leave as "mock" for local content files.
CMS_PROVIDER=mock

# Required when CMS_PROVIDER=sanity
SANITY_PROJECT_ID=
SANITY_DATASET=production
SANITY_API_VERSION=2024-01-01
# Optional: only needed for private datasets or write operations
SANITY_API_TOKEN=

# ── Auth (NextAuth.js) ────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
# The canonical URL of your deployment (no trailing slash)
NEXTAUTH_URL=http://localhost:3000

# GitHub OAuth app credentials — create at https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Your GitHub username; only this account will be allowed to sign in to /admin.
# Leave empty to allow any authenticated GitHub user.
ALLOWED_GITHUB_LOGIN=j-falcon122
